# ============================================================
# .gitignore for empirical research workflow
# Protect raw data, private datasets, temporary files, and outputs
# ============================================================


# ------------------------------------------------------------
# 1. Raw and private data
# ------------------------------------------------------------

# Never commit raw data files
data/raw/*
!data/raw/.gitkeep

# Do not commit intermediate generated datasets by default
data/interim/*
!data/interim/.gitkeep

# Do not commit processed datasets by default
data/processed/*
!data/processed/.gitkeep

# Dictionary folder can keep documentation, but ignore large data files
data/dictionary/*.xlsx
data/dictionary/*.xls
data/dictionary/*.csv
data/dictionary/*.dta
data/dictionary/*.sav
data/dictionary/*.rds
data/dictionary/*.RData


# ------------------------------------------------------------
# 2. Common data file formats
# ------------------------------------------------------------

*.xlsx
*.xls
*.csv
*.tsv
*.txt
*.dta
*.sav
*.sas7bdat
*.por
*.rds
*.RData
*.fst
*.feather
*.parquet
*.arrow
*.zip
*.rar
*.7z


# ------------------------------------------------------------
# 3. Outputs generated by code
# ------------------------------------------------------------

# Ignore generated tables, figures, logs, and manuscript outputs by default
outputs/tables/*
!outputs/tables/.gitkeep

outputs/figures/*
!outputs/figures/.gitkeep

outputs/logs/*
!outputs/logs/.gitkeep

outputs/manuscript/*
!outputs/manuscript/.gitkeep


# ------------------------------------------------------------
# 4. R temporary and project files
# ------------------------------------------------------------

.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj

# renv library can be large; keep lockfile if used
renv/library/
renv/staging/
renv/python/
renv/sandbox/


# ------------------------------------------------------------
# 5. Python temporary files
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*.pyo
*.pyd
.ipynb_checkpoints/
.venv/
venv/
env/
.env


# ------------------------------------------------------------
# 6. Quarto / Markdown / manuscript temporary files
# ------------------------------------------------------------

.quarto/
*_files/
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc


# ------------------------------------------------------------
# 7. System files
# ------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini


# ------------------------------------------------------------
# 8. Temporary editor files
# ------------------------------------------------------------

*.tmp
*.temp
*.bak
*.swp
*.swo
~$*
